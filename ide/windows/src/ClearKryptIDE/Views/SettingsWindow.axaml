<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClearKryptIDE.Views.SettingsWindow"
        Title="Settings"
        Width="560" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="false">
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="ClearKrypt SDK" FontWeight="SemiBold" />
    <TextBlock Opacity="0.7" TextWrapping="Wrap"
               Text="Path to the clearkrypt executable (or its SDK bin folder). Leave empty to use the CLEARKRYPT_SDK environment variable, then PATH." />
    <TextBox Name="SdkPathBox" Watermark="e.g. C:\clearkrypt-sdk\bin\clearkrypt.cmd" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="Cancel" Click="OnCancelClicked" />
      <Button Content="Save" Classes="accent" Click="OnSaveClicked" />
    </StackPanel>
  </StackPanel>
</Window>
