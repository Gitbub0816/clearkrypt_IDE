exports[`language power pack end to end > builds match, optionals, interpolation, and typed throws for all targets 3`] = `
"// Generated by ClearKrypt 0.1.0 from src/main.ck (module app.orders).
// Do not edit. Changes will be overwritten.

import type { ID } from '../clearkrypt';

export type OrderStatus = 'pending' | 'shipped' | 'delivered';

export type OrderError =
  | { kind: 'notFound' }
  | { kind: 'rejected'; reason: string };

export interface Customer {
  readonly name: string;
}

export interface Order {
  readonly id: ID;
  readonly label: string;
  readonly note: string | null;
  readonly customer: Customer | null;
  readonly status: OrderStatus;
}

export function statusLabel(status: OrderStatus): string {
  const label = (() => {
    const matched = status;
    switch (matched) {
      case "pending":
        return "waiting";
      case "shipped":
        return "on the way";
      case "delivered":
        return "done";
    }
    throw new Error("unreachable match");
  })();
  return label;
}

export function describe(order: Order): string {
  const note = order.note ?? "no note";
  return \`Order \${order.label} (\${statusLabel(order.status)}): \${note}\`;
}

export function customerName(order: Order): string {
  return order.customer?.name ?? "anonymous";
}

export function noteLength(order: Order): number {
  const note = order.note;
  if (note !== null) {
    return lengthOf(note);
  } else {
    return 0;
  }
}

export function lengthOf(text: string): number {
  return 1;
}

/**
 * @throws {OrderError}
 */
export function requireShipped(status: OrderStatus): string {
  const matched = status;
  switch (matched) {
    case "shipped":
      return "ok";
    default:
      return "not yet";
  }
}

/**
 * @throws {OrderError}
 */
export function checkOrder(order: Order): string {
  if (order.label === "") {
    throw { kind: "rejected", reason: "missing label" };
  }
  return requireShipped(order.status);
}

export function defaultStatus(): OrderStatus {
  return "pending";
}
"
`;

exports[`nested (local) functions end to end > builds capturing and self-recursive local functions for all targets 1`] = `
"// Generated by ClearKrypt 0.1.0 from src/main.ck (module app.nested).
// Do not edit. Changes will be overwritten.

public func triangular(n: Int) -> Int {
    func sumUpTo(current: Int) -> Int {
        if current <= 0 {
            return 0
        }
        return current + sumUpTo(current: current - 1)
    }
    return sumUpTo(current: n)
}

public func discountedTotal(base: Int, discountPercent: Int) -> Int {
    func applyDiscount(amount: Int) -> Int {
        return amount - amount * discountPercent / 100
    }
    func addServiceFee(amount: Int) -> Int {
        return amount + 5
    }
    return addServiceFee(amount: applyDiscount(amount: base))
}

public func describeTotal(base: Int, discountPercent: Int) -> String {
    let total = discountedTotal(base: base, discountPercent: discountPercent)
    return "Total: \\(total)"
}
"
`;

