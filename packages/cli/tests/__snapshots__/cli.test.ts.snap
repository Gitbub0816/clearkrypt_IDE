"// Generated by ClearKrypt 0.1.0 from src/main.ck (module app.orders).
// Do not edit. Changes will be overwritten.

public func statusLabel(status: OrderStatus) -> String {
    let label = switch status {
    case .pending:
        "waiting"
    case .shipped:
        "on the way"
    case .delivered:
        "done"
    }
    return label
}

public func describe(order: Order) -> String {
    let note = order.note ?? "no note"
    return "Order \\(order.label) (\\(statusLabel(status: order.status))): \\(note)"
}

public func customerName(order: Order) -> String {
    return order.customer?.name ?? "anonymous"
}

public func noteLength(order: Order) -> Int {
    if let note = order.note {
        return lengthOf(text: note)
    } else {
        return 0
    }
}

public func lengthOf(text: String) -> Int {
    return 1
}

/// - Throws: OrderError
public func requireShipped(status: OrderStatus) throws -> String {
    return switch status {
    case .shipped:
        "ok"
    default:
        "not yet"
    }
}

/// - Throws: OrderError
public func checkOrder(order: Order) throws -> String {
    if order.label == "" {
        throw OrderError.rejected(reason: "missing label")
    }
    return try requireShipped(status: order.status)
}

public func defaultStatus() -> OrderStatus {
    return OrderStatus.pending
}
"
