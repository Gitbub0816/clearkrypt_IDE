        OrderStatus.Pending -> "waiting"
        OrderStatus.Shipped -> "on the way"
        OrderStatus.Delivered -> "done"
    }
    return label
}

fun describe(order: Order): String {
    val note = order.note ?: "no note"
    return "Order \${order.label} (\${statusLabel(status = order.status)}): \${note}"
}

fun customerName(order: Order): String {
    return order.customer?.name ?: "anonymous"
}

fun noteLength(order: Order): Int {
    val note = order.note
    if (note != null) {
        return lengthOf(text = note)
    } else {
        return 0
    }
}

fun lengthOf(text: String): Int {
    return 1
}

/**
 * @throws OrderError
 */
fun requireShipped(status: OrderStatus): String {
    return when (status) {
        OrderStatus.Shipped -> "ok"
        else -> "not yet"
    }
}

/**
 * @throws OrderError
 */
fun checkOrder(order: Order): String {
    if (order.label == "") {
        throw OrderError.Rejected(reason = "missing label")
    }
    return requireShipped(status = order.status)
}

fun defaultStatus(): OrderStatus {
    return OrderStatus.Pending
}
