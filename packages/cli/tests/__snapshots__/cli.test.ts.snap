"// Generated by ClearKrypt 0.1.0 from src/main.ck (module app.nested).
// Do not edit. Changes will be overwritten.

export function triangular(n: number): number {
  function sumUpTo(current: number): number {
    if (current <= 0) {
      return 0;
    }
    return current + sumUpTo(current - 1);
  }
  return sumUpTo(n);
}

export function discountedTotal(base: number, discountPercent: number): number {
  function applyDiscount(amount: number): number {
    return amount - amount * discountPercent / 100;
  }
  function addServiceFee(amount: number): number {
    return amount + 5;
  }
  return addServiceFee(applyDiscount(base));
}

export function describeTotal(base: number, discountPercent: number): string {
  const total = discountedTotal(base, discountPercent);
  return \`Total: \${total}\`;
}
"
`;
