// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`lowerProject - IR snapshots > lowers async throws functions and error declarations 1`] = `
"Module app.net (syntax/async-throws.ck)
  Error NetworkError
    Case timeout
    Case server(message: String)
  Model RemoteUser
    Field id: ID
    Field name: String
  Function fetchUser(id: ID) async throws NetworkError -> RemoteUser
    Return construct app.net.RemoteUser(id: param(id) : ID, name: "Remote" : String) : RemoteUser
"
`;

exports[`lowerProject - IR snapshots > lowers functions with expressions and control flow 1`] = `
"Module app.text (syntax/simple-function.ck)
  Function fullName(first: String, last: String) -> String
    Return ((param(first) : String + " " : String) : String + param(last) : String) : String
  Function larger(a: Int, b: Int) -> Int
    If (param(a) : Int > param(b) : Int) : Bool
      Return param(a) : Int
    Else
      Return param(b) : Int
  Function describeCount(count: Int) -> String
    Let label: String = "items" : String
    If (param(count) : Int == 1 : Int) : Bool
      Return "1 item" : String
    Return ("many " : String + local(label) : String) : String
"
`;

exports[`lowerProject - IR snapshots > lowers hello-world 1`] = `
"Module app.main (projects/hello-world/src/main.ck)
  Model Greeting
    Field id: ID
    Field message: String
    Field isFriendly: Bool = true : Bool
  Function greetingText(greeting: Greeting) -> String
    Return param(greeting) : Greeting.message : String
  Function friendlyGreeting(message: String) -> Greeting
    Return construct app.main.Greeting(id: "greeting-1" : String, message: param(message) : String) : Greeting
"
`;

exports[`lowerProject - IR snapshots > lowers the power pack: match, optionals, interpolation, throw, try 1`] = `
"Module app.orders (syntax/power-pack.ck)
  Enum OrderStatus (simple)
    Case pending
    Case shipped
    Case delivered
  Error OrderError
    Case notFound
    Case rejected(reason: String)
  Model Customer
    Field name: String
  Model Order
    Field id: ID
    Field label: String
    Field note: String?
    Field customer: Customer?
    Field status: OrderStatus
  Function statusLabel(status: OrderStatus) -> String
    Let label: String = match(param(status) : OrderStatus) { pending -> "waiting" : String; shipped -> "on the way" : String; delivered -> "done" : String } : String
    Return local(label) : String
  Function describe(order: Order) -> String
    Let note: String = (param(order) : Order.note : String? ?? "no note" : String) : String
    Return interp("Order \\(param(order) : Order.label : String) (\\(call app.orders.statusLabel(status: param(order) : Order.status : OrderStatus) : String)): \\(local(note) : String)") : String
  Function customerName(order: Order) -> String
    Return (param(order) : Order.customer : Customer??.name : String? ?? "anonymous" : String) : String
  Function noteLength(order: Order) -> Int
    IfLet note: String = param(order) : Order.note : String?
      Return call app.orders.lengthOf(text: local(note) : String) : Int
    Else
      Return 0 : Int
  Function lengthOf(text: String) -> Int
    Return 1 : Int
  Function requireShipped(status: OrderStatus) throws OrderError -> String
    Return match(param(status) : OrderStatus) { shipped -> "ok" : String; else -> "not yet" : String } : String
  Function checkOrder(order: Order) throws OrderError -> String
    If (param(order) : Order.label : String == "" : String) : Bool
      Throw case OrderError.rejected(reason: "missing label" : String) : OrderError
    Return try call app.orders.requireShipped(status: param(order) : Order.status : OrderStatus) : String
  Function defaultStatus() -> OrderStatus
    Return case OrderStatus.pending : OrderStatus
"
`;

exports[`lowerProject - IR snapshots > lowers the two-modules project with cross-module references 1`] = `
"Module app.models (projects/two-modules/src/models.ck)
  Model User
    Field id: ID
    Field name: String
Module app.api (projects/two-modules/src/api.ck)
  Function welcome(user: User) -> String
    Return ("Welcome, " : String + param(user) : User.name : String) : String
"
`;
