    Let label = match status { pending -> "waiting"; shipped -> "on the way"; delivered -> "done" } 27:3-31:4
    Return label 32:3-32:15
  Function describe(order: Order) -> String 35:1-38:2
    Let note = order.note ?? "no note" 36:3-36:37
